{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "pilotfish": {
      "description": "Opt-in multi-model orchestrator. Plans and reviews in the primary session, delegates execution by role, and independently verifies non-trivial work.",
      "mode": "primary",
      "prompt": "{file:./pilotfish/prompts/pilotfish.md}",
      "permission": {
        "task": {
          "*": "deny",
          "scout": "allow",
          "Explore": "allow",
          "mech-executor": "allow",
          "executor": "allow",
          "verifier": "allow",
          "security-executor": "allow"
        }
      }
    },
    "scout": {
      "description": "Narrow read-only reconnaissance for locating files, symbols, usages, configuration values, and direct answers with file references.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/scout.md}",
      "permission": {
        "*": "deny",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      }
    },
    "Explore": {
      "description": "Broad read-only codebase exploration across many files, directories, and naming conventions; returns locations and a concise synthesis.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/Explore.md}",
      "permission": {
        "*": "deny",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      }
    },
    "mech-executor": {
      "description": "Executes fully specified mechanical work such as pattern refactors, conventional tests, documentation, bulk edits, and focused test runs.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/mech-executor.md}",
      "permission": {
        "task": "deny"
      }
    },
    "executor": {
      "description": "Implements features, bug fixes, integrations, and design-sensitive refactors that require local engineering judgment.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/executor.md}",
      "permission": {
        "task": "deny"
      }
    },
    "verifier": {
      "description": "Fresh-context adversarial verification of non-trivial completed work; reproduces evidence and returns CONFIRMED or REFUTED without fixing findings.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/verifier.md}",
      "permission": {
        "edit": "deny",
        "task": "deny",
        "bash": {
          "*": "allow",
          "git commit*": "deny",
          "git push*": "deny",
          "git reset*": "deny",
          "git checkout*": "deny",
          "git restore*": "deny",
          "git switch*": "deny",
          "git clean*": "deny",
          "git merge*": "deny",
          "git rebase*": "deny",
          "git cherry-pick*": "deny",
          "git stash*": "deny",
          "rm *": "deny"
        }
      }
    },
    "security-executor": {
      "description": "Handles security-sensitive implementation and analysis involving authentication, authorization, secrets, crypto, validation, hardening, or vulnerabilities.",
      "mode": "subagent",
      "prompt": "{file:./pilotfish/prompts/security-executor.md}",
      "permission": {
        "task": "deny"
      }
    }
  }
}
